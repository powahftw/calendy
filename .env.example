# Firebase Web App config from Firebase Console -> Project settings -> General -> Your apps
VITE_FIREBASE_API_KEY="your-firebase-web-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-messaging-sender-id"
VITE_FIREBASE_APP_ID="your-firebase-app-id"

# Google OAuth Web client ID for import-only Calendar access
VITE_GOOGLE_CALENDAR_CLIENT_ID="your-google-oauth-client-id.apps.googleusercontent.com"
